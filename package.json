{
  "name": "formulas-pdf-parser",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "start:api": "tsx src/index.ts --mode=api",
    "start:both": "tsx src/index.ts --mode=both",
    "start:worker": "tsx src/worker.ts",
    "test:e2e:drive-real": "bash scripts/e2e-drive-real.sh",
    "test:e2e:drive-real:persistent": "KEEP_RUNTIME_UP=1 KEEP_ENV_UP=1 bash scripts/e2e-drive-real.sh",
    "stop:e2e:drive-real": "bash scripts/e2e-drive-real-stop.sh",
    "deploy:do:prod": "sh deploy/digitalocean/scripts/deploy.sh",
    "deploy:do:prod:issue-cert": "sh deploy/digitalocean/scripts/issue-cert.sh",
    "deploy:do:prod:update": "sh deploy/digitalocean/scripts/update-and-deploy.sh",
    "deploy:do:prod:smoke": "sh deploy/digitalocean/scripts/smoke-test.sh",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@napi-rs/canvas": "^0.1.80",
    "bullmq": "^5.12.12",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "google-auth-library": "^10.0.0",
    "googleapis": "^150.0.1",
    "ioredis": "^5.4.2",
    "mysql2": "^3.14.1",
    "pdfjs-dist": "^4.10.38",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
