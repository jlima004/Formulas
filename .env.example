MYSQL_PORT=3306
MYSQL_DATABASE=formulas
MYSQL_USER=formulas
MYSQL_PASSWORD=formulas
MYSQL_ROOT_PASSWORD=root

# App mode: batch | api | both
API_MODE=batch
API_HOST=0.0.0.0
API_PORT=3000

# Queue
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_QUEUE_NAME=drive-file-events

# Drive integration
DRIVE_FOLDER_ID=
DRIVE_SHARED_DRIVE_ID=
DRIVE_WEBHOOK_TOKEN=
DRIVE_WEBHOOK_ADDRESS=
DRIVE_TEMP_DIR=/tmp/formulas-drive
DRIVE_SYNC_MAX_FILES=200
DRIVE_WATCH_TTL_SECONDS=86400
DRIVE_WATCH_AUTO_RENEW_ENABLED=true
DRIVE_WATCH_RENEW_BEFORE_SECONDS=900
DRIVE_WATCH_CHECK_INTERVAL_SECONDS=60

# Google auth (use one strategy)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly